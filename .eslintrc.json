{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "prefer-const": "warn",
    "eqeqeq": ["error", "smart"],
    "no-var": "error",
    "no-implicit-globals": "error",
    "no-undef": "error"
  }
}
